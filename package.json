{
  "name": "web-copilot",
  "devDependencies": {
    "prettier": "^3",
    "turbo": "^2"
  },
  "packageManager": "bun@1.3.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
