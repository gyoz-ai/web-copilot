{
  "name": "@gyoz-ai/extension",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:safari": "wxt build --browser safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "zip:safari": "wxt zip --browser safari",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf .output .wxt dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@gyoz-ai/engine": "workspace:*",
    "@wxt-dev/module-react": "^1.1.4",
    "ai": "^6.0.141",
    "preact": "^10.29.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wxt": "^0.20.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/chrome": "^0.0.309",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.8.9",
    "typescript": "^5"
  }
}
